{
  "name": "@xiaohao0725/logs-sdk",
  "version": "0.3.0",
  "description": "日志管理平台 Node.js SDK，提供 Express/Koa/Fastify 中间件，自动采集 HTTP 请求日志并上报",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "logs",
    "sdk",
    "middleware",
    "express",
    "koa",
    "fastify",
    "logging"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/koa": "^2.15.0",
    "@types/node": "^24.12.3",
    "@types/uuid": "^10.0.0",
    "fastify": "^5.9.0",
    "typescript": "~5.8.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "fastify": "^4.0.0 || ^5.0.0",
    "koa": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "koa": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
